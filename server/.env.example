# Server Environment Variables
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=production

# MongoDB Atlas - create a free cluster at https://mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lms-platform?retryWrites=true&w=majority

# JWT - generate a secure random string
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Cloudinary - create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini AI - get API key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=LearnHub
FROM_EMAIL=noreply@learnhub.com

# Judge0 API (optional - for code execution)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_judge0_api_key

# CORS - your frontend URL after deployment
CLIENT_URL=https://your-frontend.vercel.app
